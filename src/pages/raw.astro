---
import { getCollection, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);

const rendered = await Promise.all(posts.map(async (post) => {
	const { Content } = await render(post);
	return { post, Content };
}));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Raw Log — ${SITE_TITLE}`} description="Every entry. One page. For me." />
		<style>
			main {
				max-width: 720px;
				margin: 0 auto;
				padding: 3rem 1.5rem 5rem;
			}

			/* ── Entry wrapper ── */
			.entry {
				margin-bottom: 5rem;
			}

			/* ── Timestamp ── */
			.entry-date {
				display: block;
				font-family: 'JetBrains Mono', 'Fira Code', monospace;
				font-size: 0.72rem;
				letter-spacing: 0.12em;
				color: var(--accent-glow);
				opacity: 0.55;
				margin-bottom: 0.5rem;
				text-transform: uppercase;
			}

			/* ── Entry title — this is a chapter of my life ── */
			.entry-title {
				font-size: 1.6rem;
				font-weight: 700;
				color: #ffffff;
				margin: 0 0 2rem 0;
				line-height: 1.2;
				letter-spacing: -0.02em;
			}

			/* ── Body copy — I want to actually read this ── */
			.entry-content {
				font-size: 1.05rem;
				line-height: 1.85;
				color: rgba(235, 235, 235, 0.88);
			}

			.entry-content p {
				margin-bottom: 1.2rem;
			}

			/* ── Section headings inside entries ── */
			.entry-content h2 {
				font-size: 0.78rem;
				font-family: 'JetBrains Mono', 'Fira Code', monospace;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: var(--accent-glow);
				margin: 2.5rem 0 1rem;
				padding-bottom: 0.4rem;
				border-bottom: 1px solid rgba(180, 79, 255, 0.2);
			}

			/* ── Blockquotes — the lines worth keeping ── */
			.entry-content blockquote {
				border-left: 3px solid var(--accent);
				padding: 0.75rem 1.25rem;
				margin: 1.75rem 0;
				background: rgba(180, 79, 255, 0.05);
				border-radius: 0 6px 6px 0;
			}

			.entry-content blockquote p {
				margin: 0;
				color: rgba(255, 255, 255, 0.9);
				font-style: italic;
				font-size: 1.05rem;
				line-height: 1.7;
			}

			.entry-content blockquote em {
				font-style: normal;
				color: #fff;
			}

			/* ── Inline code ── */
			.entry-content code {
				font-family: 'JetBrains Mono', 'Fira Code', monospace;
				font-size: 0.85em;
				background: rgba(180, 79, 255, 0.1);
				padding: 0.15em 0.4em;
				border-radius: 3px;
				color: var(--accent-glow);
			}

			/* ── HR inside entries ── */
			.entry-content hr {
				border: none;
				border-top: 1px solid rgba(180, 79, 255, 0.12);
				margin: 1.75rem 0;
			}

			/* ── Lists ── */
			.entry-content ul {
				padding-left: 1.25rem;
				margin-bottom: 1.2rem;
			}

			.entry-content li {
				margin-bottom: 0.4rem;
				color: rgba(235, 235, 235, 0.88);
			}

			/* ── Divider between entries ── */
			.entry-divider {
				text-align: center;
				margin: 4rem 0;
				color: var(--accent-glow);
				opacity: 0.3;
				font-size: 1.1rem;
				letter-spacing: 0.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			{rendered.map(({ post, Content }, index) => (
				<div class="entry">
					<span class="entry-date">
						{post.data.pubDate.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'long', day: 'numeric' })}
					</span>
					<h1 class="entry-title">{post.data.title}</h1>
					<div class="entry-content">
						<Content />
					</div>
					{index < rendered.length - 1 && (
						<div class="entry-divider">⚡ ⚡ ⚡</div>
					)}
				</div>
			))}
		</main>
		<Footer />
	</body>
</html>
